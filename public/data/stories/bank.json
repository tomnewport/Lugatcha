  {
    "id": "bank.counting-lesson",
    "theme": "bank",
    "title": {
      "en": "Learning the Numbers",
      "uz": "Raqamlarni o'rganish"
    },
    "sentences": [
      {
        "uzbek": "O'zbek puli katta raqamlar bilan.",
        "english": "Uzbek money comes in big numbers."
      },
      {
        "uzbek": "Bir choy ming so'm turadi.",
        "english": "One tea costs a thousand som."
      },
      {
        "uzbek": "Bir osh o'ttiz ming so'm.",
        "english": "One plov is thirty thousand som."
      },
      {
        "uzbek": "Avval men adashdim.",
        "english": "At first I got confused."
      },
      {
        "uzbek": "Lekin sekin-sekin o'rgandim.",
        "english": "But slowly I learned."
      },
      {
        "uzbek": "Endi men tez sanayman!",
        "english": "Now I count quickly!"
      }
    ],
    "glossary": {
