    "title": {
      "en": "My First Som",
      "ru": "Мой первый сум",
      "uz": "Birinchi so'mim"
    },
    "sentences": [
      {
        "uzbek": "Men bankka pul almashtirishga bordim.",
        "english": "I went to the bank to change money.",
        "russian": "Я пошёл в банк, чтобы поменять деньги."
      },
      {
        "uzbek": "Men yuz dollar berdim.",
        "english": "I gave one hundred dollars.",
        "russian": "Я дал сто долларов."
      },
      {
        "uzbek": "Ayol menga ko'p so'm berdi.",
        "english": "The woman gave me a lot of som.",
        "russian": "Женщина дала мне много сумов."
      },
      {
        "uzbek": "Pul katta dasta edi!",
        "english": "The money was a big bundle!",
        "russian": "Деньги были большой пачкой!"
      },
      {
        "uzbek": "Men pulni sanadim va xursand bo'ldim.",
        "english": "I counted the money and was happy.",
        "russian": "Я пересчитал деньги и обрадовался."
      },
      {
        "uzbek": "Endi men osh va sovg'a sotib olaman.",
        "english": "Now I will buy plov and gifts.",
        "russian": "Теперь я куплю плов и подарки."
      }
    ],
