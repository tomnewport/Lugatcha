    "sentences": [
      {
        "uzbek": "Men bankka pul almashtirishga bordim.",
        "english": "I went to the bank to change money."
      },
      {
        "uzbek": "Men yuz dollar berdim.",
        "english": "I gave one hundred dollars."
      },
      {
        "uzbek": "Ayol menga ko'p so'm berdi.",
        "english": "The woman gave me a lot of som."
      },
