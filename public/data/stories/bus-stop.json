  {
    "id": "bus-stop.helpful-driver",
    "theme": "bus-stop",
    "title": {
      "en": "The Helpful Driver",
      "uz": "Mehribon haydovchi"
    },
    "sentences": [
      {
        "uzbek": "Men qaysi bekatda tushishni bilmadim.",
        "english": "I did not know which stop to get off at."
      },
      {
        "uzbek": "Haydovchiga manzilni aytdim.",
        "english": "I told the driver the address."
      },
      {
        "uzbek": "U \"men aytaman\" dedi.",
        "english": "He said, \"I will tell you.\""
      },
      {
        "uzbek": "Bekatga kelganda, u menga aytdi.",
        "english": "When we reached the stop, he told me."
      },
      {
        "uzbek": "Men tushdim va rahmat aytdim.",
        "english": "I got off and said thank you."
      },
      {
        "uzbek": "Bu yerda hamma yordam beradi.",
        "english": "Here everyone helps."
      }
    ],
    "glossary": {
      "Men": "I",
      "qaysi": "which",
      "bekatda": "at the stop",
      "tushishni": "getting off (object)",
      "bilmadim": "I did not know",
      "Haydovchiga": "to the driver",
      "manzilni": "the address (object)",
      "aytdim": "I told",
      "U": "he",
      "men": "I",
      "aytaman": "I will tell",
      "dedi": "said",
      "Bekatga": "to the stop",
      "kelganda": "when (we) came",
      "menga": "to me",
      "aytdi": "told",
      "tushdim": "I got off",
      "va": "and",
      "rahmat": "thanks",
      "hamma": "everyone",
      "yordam": "help",
