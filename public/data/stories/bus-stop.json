[
  {
    "id": "bus-stop.village-road",
    "theme": "bus-stop",
    "title": {
      "en": "The Road to the Village",
      "uz": "Qishloqqa yo'l"
    },
    "sentences": [
      {
        "uzbek": "Men kichik qishloqqa bordim.",
        "english": "I went to a small village."
      },
      {
        "uzbek": "Bekatda uzoq kutdim.",
        "english": "I waited a long time at the stop."
      },
      {
        "uzbek": "Nihoyat eski avtobus keldi.",
        "english": "At last an old bus came."
      },
      {
        "uzbek": "Haydovchi kulib salom berdi.",
        "english": "The driver smiled and greeted me."
      },
      {
        "uzbek": "Yo'lda paxta dalalari bor edi.",
        "english": "On the road there were cotton fields."
      },
      {
        "uzbek": "Qishloq tinch va go'zal edi.",
        "english": "The village was quiet and lovely."
      }
    ],
    "glossary": {
      "Men": "I",
      "kichik": "small",
      "qishloqqa": "to the village",
      "bordim": "I went",
      "Bekatda": "at the stop",
      "uzoq": "long",
      "kutdim": "I waited",
      "Nihoyat": "at last",
      "eski": "old",
      "avtobus": "bus",
      "keldi": "came",
      "Haydovchi": "the driver",
      "kulib": "smiling",
