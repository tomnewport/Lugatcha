  {
    "id": "choyxona.the-guest",
    "theme": "choyxona",
    "title": {
      "en": "A Guest is a Blessing",
      "uz": "Mehmon — tabarruk"
    },
    "sentences": [
      {
        "uzbek": "Men choyxonaga yolg'iz kirdim.",
        "english": "I went into the teahouse alone."
      },
      {
        "uzbek": "Bir oila meni dasturxonga taklif qildi.",
        "english": "A family invited me to their table."
      },
      {
        "uzbek": "Ular non va osh berdi.",
        "english": "They gave me bread and plov."
      },
      {
        "uzbek": "Men pul taklif qildim, lekin ular kulishdi.",
        "english": "I offered money, but they laughed."
      },
      {
        "uzbek": "\"Mehmon — Xudoning sovg'asi,\" dedilar.",
        "english": "\"A guest is God's gift,\" they said."
      },
      {
        "uzbek": "Men bu kunni hech qachon unutmayman.",
        "english": "I will never forget this day."
      }
    ],
    "glossary": {
      "Men": "I",
      "choyxonaga": "into the teahouse",
      "yolg'iz": "alone",
      "kirdim": "I entered",
      "Bir": "one / a",
