[
  {
    "id": "choyxona.under-the-vine",
    "theme": "choyxona",
    "title": {
      "en": "Under the Grapevine",
      "ru": "Под виноградной лозой",
      "uz": "Tok ostida"
    },
    "sentences": [
      {
        "uzbek": "Choyxona bog'ida tok bor edi.",
        "english": "In the teahouse garden there was a grapevine.",
        "russian": "В саду чайханы росла виноградная лоза."
      },
      {
        "uzbek": "Men so'rida o'tirdim.",
        "english": "I sat on the platform.",
        "russian": "Я сидел на топчане."
      },
      {
        "uzbek": "Bir keksa odam menga choy quydi.",
        "english": "An old man poured me tea.",
        "russian": "Старик налил мне чаю."
      },
      {
        "uzbek": "Biz uzoq suhbatlashdik.",
        "english": "We talked for a long time.",
        "russian": "Мы долго беседовали."
      },
      {
        "uzbek": "U menga shahar haqida gapirdi.",
        "english": "He told me about the city.",
        "russian": "Он рассказал мне о городе."
      },
      {
        "uzbek": "Bu yerda begona odam yo'q.",
        "english": "Here there are no strangers.",
        "russian": "Здесь нет чужих."
      }
    ],
