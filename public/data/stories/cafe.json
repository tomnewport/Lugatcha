  {
    "id": "cafe.rainy-afternoon",
    "theme": "cafe",
    "title": {
      "en": "A Rainy Afternoon",
      "ru": "Дождливый день",
      "uz": "Yomg'irli kun"
    },
    "sentences": [
      {
        "uzbek": "Tashqarida yomg'ir yog'di.",
        "english": "Outside it rained.",
        "russian": "На улице шёл дождь."
      },
      {
        "uzbek": "Men issiq kafega kirdim.",
        "english": "I went into a warm cafe.",
        "russian": "Я зашёл в тёплое кафе."
      },
      {
        "uzbek": "Issiq choy va tort buyurdim.",
        "english": "I ordered hot tea and cake.",
        "russian": "Я заказал горячий чай и торт."
      },
      {
        "uzbek": "Men kitob o'qidim va dam oldim.",
        "english": "I read a book and rested.",
        "russian": "Я читал книгу и отдыхал."
      },
      {
        "uzbek": "Yomg'ir deraza oynasiga urildi.",
        "english": "The rain knocked on the window pane.",
        "russian": "Дождь стучал по оконному стеклу."
      },
      {
        "uzbek": "Bu juda tinch va yoqimli edi.",
        "english": "It was very peaceful and pleasant.",
        "russian": "Это было очень спокойно и приятно."
      }
