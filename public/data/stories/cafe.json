    "sentences": [
      {
        "uzbek": "Har ertalab men kafega boraman.",
        "english": "Every morning I go to the cafe.",
        "russian": "Каждое утро я хожу в кафе."
      },
      {
        "uzbek": "Men bitta katta kofe buyuraman.",
        "english": "I order one big coffee.",
        "russian": "Я заказываю один большой кофе."
      },
      {
        "uzbek": "Ofitsiant meni taniydi.",
        "english": "The waiter knows me.",
        "russian": "Официант меня знает."
      },
      {
        "uzbek": "Men deraza yonida o'tiraman.",
        "english": "I sit by the window.",
        "russian": "Я сижу у окна."
      },
      {
        "uzbek": "Ko'chada odamlar ishga ketadi.",
        "english": "On the street people go to work.",
        "russian": "На улице люди идут на работу."
      },
      {
        "uzbek": "Bu mening sevimli vaqtim.",
        "english": "This is my favourite time.",
        "russian": "Это моё любимое время."
      }
