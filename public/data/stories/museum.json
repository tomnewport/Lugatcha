    "sentences": [
      {
        "uzbek": "Bu muzey eski usta uyi edi.",
        "english": "This museum was an old master's house.",
        "russian": "Этот музей был домом старого мастера."
      },
      {
        "uzbek": "Usta chiroyli sopol idishlar yasadi.",
        "english": "The master made beautiful ceramic dishes.",
        "russian": "Мастер делал красивую керамическую посуду."
      },
      {
        "uzbek": "Hovlida katta tut daraxti bor.",
        "english": "In the courtyard there is a big mulberry tree.",
        "russian": "Во дворе растёт большое тутовое дерево."
      },
      {
        "uzbek": "Men ko'k piyolani ko'rdim.",
        "english": "I saw a blue tea bowl.",
        "russian": "Я увидел синюю пиалу."
      },
      {
        "uzbek": "U yuz yoshda, lekin yangi kabi.",
