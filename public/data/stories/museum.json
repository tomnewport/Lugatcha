        "uzbek": "Unda Buyuk ipak yo'li bor edi.",
        "english": "The Great Silk Road was on it."
      },
      {
        "uzbek": "Karvonlar Samarqandga bordi.",
        "english": "Caravans went to Samarkand."
      },
