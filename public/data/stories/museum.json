  {
    "id": "museum.old-map",
    "theme": "museum",
    "title": {
      "en": "The Old Map",
      "ru": "Старая карта",
      "uz": "Eski xarita"
    },
    "sentences": [
      {
        "uzbek": "Muzeyda men eski xaritani ko'rdim.",
        "english": "In the museum I saw an old map.",
        "russian": "В музее я увидел старую карту."
      },
      {
        "uzbek": "Unda Buyuk ipak yo'li bor edi.",
        "english": "The Great Silk Road was on it.",
        "russian": "На ней был Великий шёлковый путь."
      },
      {
        "uzbek": "Karvonlar Samarqandga bordi.",
        "english": "Caravans went to Samarkand.",
        "russian": "Караваны шли в Самарканд."
      },
      {
        "uzbek": "Ular ipak va sopol olib keldi.",
        "english": "They brought silk and ceramics.",
        "russian": "Они привозили шёлк и керамику."
      },
      {
        "uzbek": "Men xaritaga uzoq qaradim.",
        "english": "I looked at the map for a long time.",
        "russian": "Я долго смотрел на карту."
      },
      {
        "uzbek": "Tarix shu yerda, juda yaqin edi.",
        "english": "History was right here, very near.",
        "russian": "История была прямо здесь, совсем рядом."
      }
