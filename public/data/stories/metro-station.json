    "sentences": [
      {
        "uzbek": "Toshkent metrosi juda chiroyli.",
        "english": "The Tashkent metro is very beautiful.",
        "russian": "Ташкентское метро очень красивое."
      },
      {
        "uzbek": "Har bir bekat boshqacha.",
        "english": "Every station is different.",
        "russian": "Каждая станция особенная."
      },
      {
        "uzbek": "Devorlarda rang-barang sopol bor.",
        "english": "On the walls there are colourful ceramics.",
        "russian": "На стенах есть разноцветная керамика."
      },
      {
        "uzbek": "Bir bekat saroy kabi edi.",
        "english": "One station was like a palace.",
        "russian": "Одна станция была похожа на дворец."
      },
      {
        "uzbek": "Men uzoq qarab turdim.",
        "english": "I stood and looked for a long time.",
        "russian": "Я долго стоял и смотрел."
      },
      {
        "uzbek": "Bu yer osti san'at muzeyi!",
        "english": "This is an underground art museum!",
        "russian": "Это подземный музей искусства!"
      }
