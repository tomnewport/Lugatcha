    "id": "grocery-store.the-melon",
    "theme": "grocery-store",
    "title": {
      "en": "The Famous Melon",
      "uz": "Mashhur qovun"
    },
    "sentences": [
      {
        "uzbek": "O'zbek qovuni butun dunyoda mashhur.",
        "english": "Uzbek melon is famous all over the world."
      },
      {
        "uzbek": "Men bozorda katta qovun ko'rdim.",
        "english": "I saw a big melon at the bazaar."
      },
      {
        "uzbek": "Sotuvchi menga bir bo'lak berdi.",
        "english": "The seller gave me a piece."
      },
      {
        "uzbek": "Qovun shirin va xushbo'y edi.",
        "english": "The melon was sweet and fragrant."
      },
      {
        "uzbek": "Men butun qovunni sotib oldim.",
        "english": "I bought the whole melon."
      },
      {
        "uzbek": "Bu eng shirin qovun edi!",
        "english": "It was the sweetest melon!"
      }
    ],
