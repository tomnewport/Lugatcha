    "sentences": [
      {
        "uzbek": "Ertalab men do'konga bordim.",
        "english": "In the morning I went to the shop.",
        "russian": "Утром я пошёл в магазин."
      },
      {
        "uzbek": "Men non, sut va tuxum oldim.",
        "english": "I bought bread, milk, and eggs.",
        "russian": "Я купил хлеб, молоко и яйца."
      },
      {
        "uzbek": "Sotuvchi yangi meva ko'rsatdi.",
        "english": "The seller showed me fresh fruit.",
        "russian": "Продавец показал мне свежие фрукты."
      },
      {
        "uzbek": "Men ikki kilo olma oldim.",
        "english": "I bought two kilos of apples.",
        "russian": "Я купил два килограмма яблок."
      },
      {
        "uzbek": "Olmalar shirin va pishgan edi.",
        "english": "The apples were sweet and ripe.",
        "russian": "Яблоки были сладкими и спелыми."
      },
      {
        "uzbek": "Nonushta juda mazali bo'ldi!",
        "english": "Breakfast was very delicious!",
        "russian": "Завтрак получился очень вкусным!"
      }
