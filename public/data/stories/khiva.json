    "id": "khiva.on-foot-and-by-taxi",
    "theme": "khiva",
    "title": { "en": "On Foot and by Taxi", "ru": "Пешком и на такси", "uz": "Piyoda va taksida" },
    "sentences": [
      { "uzbek": "Xiva kichik, koʻp joyga piyoda boramiz.", "english": "Khiva is small, we walk to many places.", "russian": "Хива маленькая, во многие места мы ходим пешком." },
      { "uzbek": "Ichan qalʼa ichida mashina yoʻq.", "english": "Inside the Ichan Qala there are no cars.", "russian": "Внутри Ичан-Калы нет машин." },
      { "uzbek": "Shahardan tashqariga marshrutka qatnaydi.", "english": "Marshrutkas run to outside the city.", "russian": "За город ходят маршрутки." },
      { "uzbek": "Men haydovchiga naqd pul toʻlayman.", "english": "I pay the driver cash.", "russian": "Я плачу водителю наличными." },
      { "uzbek": "Urganchga taksi bilan boramiz.", "english": "We go to Urgench by taxi.", "russian": "В Ургенч мы едем на такси." },
