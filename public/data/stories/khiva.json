    "sentences": [
      { "uzbek": "Xiva kichik va goʻzal shahar.", "english": "Khiva is a small and beautiful city.", "russian": "Хива — маленький и красивый город." },
      { "uzbek": "Baland devorlar shaharni oʻraydi.", "english": "Tall walls surround the city.", "russian": "Высокие стены окружают город." },
      { "uzbek": "Biz katta darvozadan kiramiz.", "english": "We enter through the big gate.", "russian": "Мы входим через большие ворота." },
