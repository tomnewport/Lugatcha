[
  {
    "id": "police-station.lost-phone",
    "theme": "police-station",
    "title": {
      "en": "The Lost Phone",
      "ru": "Потерянный телефон",
      "uz": "Yo'qolgan telefon"
    },
    "sentences": [
      {
        "uzbek": "Kecha telefonim yo'qoldi.",
        "english": "Yesterday my phone got lost.",
        "russian": "Вчера я потерял свой телефон."
      },
      {
        "uzbek": "Men politsiyaga bordim.",
        "english": "I went to the police.",
        "russian": "Я пошёл в полицию."
      },
      {
        "uzbek": "Yosh politsiyachi menga yordam berdi.",
        "english": "A young police officer helped me.",
        "russian": "Молодой полицейский мне помог."
      },
      {
        "uzbek": "Bir kishi telefonimni topdi.",
        "english": "Someone had found my phone.",
        "russian": "Кто-то нашёл мой телефон."
      },
      {
        "uzbek": "U uni politsiyaga olib keldi.",
        "english": "He had brought it to the police.",
        "russian": "Он принёс его в полицию."
      },
      {
        "uzbek": "Odamlar bu yerda juda halol!",
        "english": "People here are very honest!",
        "russian": "Люди здесь очень честные!"
      }
    ],
    "glossary": {
