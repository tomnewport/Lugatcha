  {
    "id": "train-station.kind-stranger",
    "theme": "train-station",
    "title": {
      "en": "A Seat by the Window",
      "uz": "Deraza yonidagi joy"
    },
    "sentences": [
      {
        "uzbek": "Poyezdda mening joyim band edi.",
        "english": "On the train my seat was taken."
      },
      {
        "uzbek": "Bir keksa odam u yerda o'tirardi.",
        "english": "An old man was sitting there."
      },
      {
        "uzbek": "Men unga chiptamni ko'rsatdim.",
        "english": "I showed him my ticket."
      },
      {
        "uzbek": "U kuldi va kechirim so'radi.",
        "english": "He smiled and apologised."
      },
      {
        "uzbek": "Biz birga choy ichdik va gaplashdik.",
        "english": "We drank tea together and talked."
      },
      {
        "uzbek": "Yo'l qisqa va yoqimli bo'ldi.",
        "english": "The journey became short and pleasant."
      }
    ],
