    "title": {
      "en": "The Train to Samarkand",
      "ru": "Поезд в Самарканд",
      "uz": "Samarqand poyezdi"
    },
    "sentences": [
      {
        "uzbek": "Ertalab men vokzalga bordim.",
        "english": "In the morning I went to the station.",
        "russian": "Утром я пошёл на вокзал."
      },
      {
        "uzbek": "Tezyurar poyezd perronda turardi.",
        "english": "The fast train was standing at the platform.",
        "russian": "Скоростной поезд стоял на перроне."
      },
      {
        "uzbek": "Men deraza yonida o'tirdim.",
        "english": "I sat by the window.",
        "russian": "Я сел у окна."
      },
      {
        "uzbek": "Poyezd tez va qulay edi.",
        "english": "The train was fast and comfortable.",
        "russian": "Поезд был быстрым и удобным."
      },
      {
        "uzbek": "Tashqarida cho'l va tog'lar edi.",
        "english": "Outside were desert and mountains.",
        "russian": "Снаружи были пустыня и горы."
      },
      {
        "uzbek": "Ikki soatda Samarqandga keldim.",
        "english": "In two hours I arrived in Samarkand.",
        "russian": "Через два часа я прибыл в Самарканд."
      }
    ],
