[
  {
    "id": "library.quiet-corner",
    "theme": "library",
    "title": {
      "en": "A Quiet Corner",
      "uz": "Jim burchak"
    },
    "sentences": [
      {
        "uzbek": "Men kutubxonaga o'qishga bordim.",
        "english": "I went to the library to read."
      },
      {
        "uzbek": "Ichkarida juda jim edi.",
        "english": "Inside it was very quiet."
      },
      {
        "uzbek": "Men oson o'zbekcha kitob topdim.",
        "english": "I found an easy Uzbek book."
      },
      {
        "uzbek": "Har bir sahifada yangi so'zlar bor edi.",
        "english": "On every page there were new words."
      },
      {
        "uzbek": "Men sekin va diqqat bilan o'qidim.",
        "english": "I read slowly and carefully."
      },
      {
        "uzbek": "Kitob — bu eng yaxshi do'st.",
        "english": "A book is the best friend."
      }
    ],
    "glossary": {
      "Men": "I",
      "kutubxonaga": "to the library",
      "o'qishga": "to read",
      "bordim": "I went",
      "Ichkarida": "inside",
      "juda": "very",
      "jim": "quiet",
      "edi": "was",
      "oson": "easy",
      "kitob": "book",
      "topdim": "I found",
      "sahifada": "on the page",
      "yangi": "new",
      "so'zlar": "words",
      "bor": "there were",
      "sekin": "slowly",
      "va": "and",
      "diqqat": "attention (diqqat bilan = carefully)",
      "bilan": "with",
