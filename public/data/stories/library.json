      "bir": "one / a"
    }
  },
  {
    "id": "library.old-poet",
    "theme": "library",
    "title": {
      "en": "The Poet Navoiy",
      "uz": "Shoir Navoiy"
    },
    "sentences": [
      {
        "uzbek": "Kutubxonada men eski kitob ko'rdim.",
        "english": "In the library I saw an old book."
      },
      {
        "uzbek": "Bu Alisher Navoiy she'rlari edi.",
        "english": "It was the poems of Alisher Navoiy."
      },
      {
        "uzbek": "U besh yuz yil oldin yashagan.",
        "english": "He lived five hundred years ago."
      },
      {
        "uzbek": "Uning so'zlari hali ham chiroyli.",
        "english": "His words are still beautiful."
      },
      {
        "uzbek": "Men bir misrani o'qidim.",
        "english": "I read one line."
      },
      {
        "uzbek": "Yaxshi she'r hech qachon qarimaydi.",
        "english": "Good poetry never grows old."
      }
    ],
    "glossary": {
      "Kutubxonada": "in the library",
      "men": "I",
      "eski": "old",
      "kitob": "book",
      "ko'rdim": "I saw",
