      "taklif": "offer (taklif qildi = offered)",
      "qildi": "did / made",
      "Biz": "we",
      "toza": "fresh / clean",
      "havoda": "in the air",
      "ichdik": "we drank",
      "Osmon": "the sky",
      "ko'm-ko'k": "deep blue",
      "tiniq": "clear",
      "bu": "this",
      "tinchlikni": "the peace (object)",
      "unutmayman": "I will not forget"
    }
  }
