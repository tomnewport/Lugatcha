[
  {
    "id": "mountain-park.to-the-top",
    "theme": "mountain-park",
    "title": {
      "en": "To the Summit",
      "ru": "К вершине",
      "uz": "Cho'qqiga"
    },
    "sentences": [
      {
        "uzbek": "Erta tongda men tog'ga chiqdim.",
        "english": "Early in the morning I climbed the mountain.",
        "russian": "Ранним утром я поднялся в гору."
      },
      {
        "uzbek": "So'qmoq tik va tor edi.",
        "english": "The path was steep and narrow.",
        "russian": "Тропа была крутой и узкой."
      },
      {
        "uzbek": "Daryo toshlar ustidan oqardi.",
        "english": "The river flowed over the stones.",
        "russian": "Река текла по камням."
      },
      {
        "uzbek": "Cho'qqida shamol sovuq edi.",
        "english": "At the summit the wind was cold.",
        "russian": "На вершине ветер был холодным."
      },
      {
        "uzbek": "Pastda butun shahar ko'rinardi.",
        "english": "Below, the whole city was visible.",
        "russian": "Внизу был виден весь город."
      },
      {
        "uzbek": "Bu manzara mehnatga arziydi!",
        "english": "This view is worth the effort!",
        "russian": "Этот вид стоит затраченных усилий!"
      }
    ],
