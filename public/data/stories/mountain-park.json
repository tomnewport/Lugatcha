  {
    "id": "mountain-park.mountain-tea",
    "theme": "mountain-park",
    "title": {
      "en": "Tea on the Mountain",
      "ru": "Чай в горах",
      "uz": "Tog'da choy"
    },
    "sentences": [
      {
        "uzbek": "Tog'da kichik choyxona bor edi.",
        "english": "On the mountain there was a small teahouse.",
        "russian": "В горах была маленькая чайхана."
      },
      {
        "uzbek": "Men charchadim va o'tirdim.",
        "english": "I was tired and sat down.",
        "russian": "Я устал и сел."
      },
      {
        "uzbek": "Bir cho'pon menga choy taklif qildi.",
        "english": "A shepherd offered me tea.",
        "russian": "Один пастух предложил мне чай."
      },
      {
        "uzbek": "Biz toza havoda choy ichdik.",
        "english": "We drank tea in the fresh air.",
        "russian": "Мы пили чай на свежем воздухе."
      },
      {
        "uzbek": "Osmon ko'm-ko'k va tiniq edi.",
        "english": "The sky was deep blue and clear.",
        "russian": "Небо было ярко-синим и ясным."
      },
      {
        "uzbek": "Men bu tinchlikni unutmayman.",
        "english": "I will not forget this peace.",
        "russian": "Я не забуду этот покой."
      }
    ],
