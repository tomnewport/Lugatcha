    "title": { "en": "Getting Around the City", "uz": "Shahar boʻylab yurish" },
    "sentences": [
      { "uzbek": "Toshkentda metro, avtobus va marshrutka bor.", "english": "In Tashkent there is the metro, the bus and the marshrutka." },
