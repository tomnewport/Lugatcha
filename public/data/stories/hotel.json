      "Registon": "Registan",
      "maydoni": "square",
      "ko'rinardi": "was visible"
    }
  },
  {
    "id": "hotel.breakfast",
    "theme": "hotel",
    "title": {
      "en": "Breakfast on the Terrace",
      "uz": "Ayvonda nonushta"
    },
    "sentences": [
      {
        "uzbek": "Ertalab men nonushtaga tushdim.",
        "english": "In the morning I went down to breakfast."
      },
      {
        "uzbek": "Ayvonda kichik stol topdim.",
        "english": "I found a small table on the terrace."
      },
      {
        "uzbek": "Non, qaymoq va choy keldi.",
        "english": "Bread, cream, and tea came."
      },
      {
        "uzbek": "Quyosh tog'lar ustida edi.",
        "english": "The sun was over the mountains."
      },
      {
        "uzbek": "Bu juda chiroyli manzara edi.",
        "english": "It was a very beautiful view."
      },
      {
        "uzbek": "Men sekin nonushta qildim.",
        "english": "I ate my breakfast slowly."
      }
    ],
    "glossary": {
