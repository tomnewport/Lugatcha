          { "speaker": "npc", "uzbek": "U yerda, chap tomonda.", "english": "Over there, on the left." },
          { "speaker": "user", "uzbek": "Tushunarli, rahmat.", "english": "Understood, thank you." }
        ]
      }
    ]
