    "scenario": "At a traditional teahouse, a friendly man at the next table starts a conversation.",
    "variants": [
      {
        "id": "choyxona.making-friends.base",
        "description": "A warm welcome and shared tea",
        "turns": [
          {
            "speaker": "npc",
            "uzbek": "Xush kelibsiz! Bu yerga o'tiring.",
            "english": "Welcome! Sit here."
          },
          {
            "speaker": "user",
            "uzbek": "Rahmat! Mehribonsiz.",
            "english": "Thank you! You are kind.",
            "tokens": [
              "Rahmat!",
              "Mehribonsiz."
            ]
          },
          {
            "speaker": "npc",
            "uzbek": "Qayerdan keldingiz?",
            "english": "Where are you from?"
          },
          {
            "speaker": "user",
            "uzbek": "Men Angliyadan keldim.",
            "english": "I came from England.",
            "tokens": [
              "Men",
              "Angliyadan",
              "keldim."
            ]
          },
          {
            "speaker": "npc",
            "uzbek": "Xush kelibsiz O'zbekistonga! Choy iching.",
            "english": "Welcome to Uzbekistan! Have some tea."
          },
          {
            "speaker": "user",
            "uzbek": "Katta rahmat!",
            "english": "Thank you very much!",
            "tokens": [
              "Katta",
              "rahmat!"
            ]
          }
        ]
      },
      {
        "id": "choyxona.making-friends.name",
        "description": "You exchange names",
        "turns": [
          {
            "speaker": "npc",
            "uzbek": "Mening ismim Bobur. Sizniki-chi?",
            "english": "My name is Bobur. And yours?"
          },
          {
            "speaker": "user",
            "uzbek": "Mening ismim Tom.",
            "english": "My name is Tom.",
            "tokens": [
              "Mening",
              "ismim",
              "Tom."
            ]
          },
          {
            "speaker": "npc",
            "uzbek": "Tanishganimdan xursandman, Tom!",
            "english": "Pleased to meet you, Tom!"
          },
          {
            "speaker": "user",
            "uzbek": "Men ham xursandman.",
            "english": "I am pleased too.",
            "tokens": [
              "Men",
              "ham",
              "xursandman."
            ]
          },
          {
            "speaker": "npc",
            "uzbek": "Endi biz do'stmiz!",
            "english": "Now we are friends!"
          }
        ]
      },
      {
        "id": "choyxona.making-friends.food",
        "description": "They insist you try the samsa",
        "turns": [
          {
            "speaker": "npc",
            "uzbek": "Somsa yedingizmi? Juda mazali!",
            "english": "Have you eaten samsa? Very tasty!"
          },
          {
            "speaker": "user",
            "uzbek": "Hali yo'q. Ko'rsataolasizmi?",
            "english": "Not yet. Can you show me?",
            "tokens": [
              "Hali",
              "yo'q.",
              "Ko'rsataolasizmi?"
            ]
          },
          {
            "speaker": "npc",
            "uzbek": "Mana, oling. Mehmon — bu tabarruk.",
            "english": "Here, take it. A guest is a blessing."
          },
          {
            "speaker": "user",
            "uzbek": "Rahmat! Juda mazali!",
            "english": "Thank you! Very tasty!",
            "tokens": [
              "Rahmat!",
              "Juda",
              "mazali!"
            ]
          },
          {
            "speaker": "npc",
            "uzbek": "Yana oling! Uyalmang.",
            "english": "Take more! Do not be shy."
          }
        ]
      },
      {
        "id": "choyxona.making-friends.family",
        "description": "They ask about your family",
        "turns": [
          {
            "speaker": "npc",
            "uzbek": "Oilangiz bormi?",
            "english": "Do you have a family?"
          },
          {
            "speaker": "user",
            "uzbek": "Ha, oilam Angliyada.",
            "english": "Yes, my family is in England.",
            "tokens": [
              "Ha,",
              "oilam",
              "Angliyada."
            ]
          },
          {
            "speaker": "npc",
            "uzbek": "Ularni sog'inasizmi?",
            "english": "Do you miss them?"
          },
          {
            "speaker": "user",
            "uzbek": "Ha, lekin bu yer go'zal.",
            "english": "Yes, but this place is lovely.",
            "tokens": [
              "Ha,",
              "lekin",
              "bu",
              "yer",
              "go'zal."
            ]
          },
          {
            "speaker": "npc",
            "uzbek": "O'zbekistonda hamma sizga do'st!",
            "english": "In Uzbekistan everyone is your friend!"
          }
        ]
      },
      {
        "id": "choyxona.making-friends.invite",
        "description": "They invite you home",
        "turns": [
          {
            "speaker": "npc",
            "uzbek": "Ertaga biznikiga keling! Osh bor.",
            "english": "Come to our house tomorrow! There is plov."
          },
          {
            "speaker": "user",
            "uzbek": "Rostdanmi? Bu katta sharaf.",
            "english": "Really? This is a great honour.",
            "tokens": [
              "Rostdanmi?",
              "Bu",
              "katta",
              "sharaf."
            ]
          },
          {
            "speaker": "npc",
            "uzbek": "Albatta! Mehmon — Xudoning sovg'asi.",
            "english": "Of course! A guest is God's gift."
          },
          {
            "speaker": "user",
            "uzbek": "Katta rahmat! Albatta kelaman.",
            "english": "Thank you very much! I will certainly come.",
            "tokens": [
              "Katta",
              "rahmat!",
              "Albatta",
              "kelaman."
            ]
          },
          {
            "speaker": "npc",
            "uzbek": "Juda yaxshi! Kutamiz.",
            "english": "Very good! We will wait for you."
          }
        ]
      }
    ]
  },
