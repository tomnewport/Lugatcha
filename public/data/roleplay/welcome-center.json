        "descriptionRu": "Спросить в ответ",
        "turns": [
          { "speaker": "npc", "uzbek": "Salom! Yaxshimisiz?", "english": "Hello! How are you?", "russian": "Привет! Как дела?" },
          { "speaker": "user", "uzbek": "Yaxshi, rahmat. Siz yaxshimisiz?", "english": "Good, thanks. Are you well?", "russian": "Хорошо, спасибо. А вы как?" },
          { "speaker": "npc", "uzbek": "Ha, rahmat.", "english": "Yes, thank you.", "russian": "Да, спасибо." }
        ]
      },
      {
        "id": "welcome-center.greetings.goodbye",
        "description": "Saying goodbye",
        "descriptionRu": "Прощание",
        "turns": [
          { "speaker": "npc", "uzbek": "Xayr!", "english": "Goodbye!", "russian": "До свидания!" },
          { "speaker": "user", "uzbek": "Xayr! Rahmat.", "english": "Goodbye! Thank you.", "russian": "До свидания! Спасибо." }
        ]
      }
