# Yandex Cloud SpeechKit credentials for audio generation (scripts/generate_audio.py).
# Copy to `.env` and fill in real values locally. NEVER commit the real .env.
# These are also read from the matching environment variables if set.

# Service-account static access key
KeyID=
SecretKey=

# Yandex Cloud folder the SpeechKit API bills against
Folder=

# Service account used to mint the key
ServiceUser=
